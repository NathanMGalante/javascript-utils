{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "jest",
            "node"
        ]
    },
    "include": [
        "*.ts",
        "formatters/**/*.ts",
        "validations/**/*.ts",
        "tests/**/*.ts"
    ]
}